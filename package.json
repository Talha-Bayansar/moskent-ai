{
  "name": "moskent-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "paraglide:compile": "node ./scripts/compile-paraglide.mjs",
    "postinstall": "pnpm paraglide:compile",
    "predev": "pnpm paraglide:compile",
    "prebuild": "pnpm paraglide:compile",
    "pretest": "pnpm paraglide:compile",
    "pretypecheck": "pnpm paraglide:compile",
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "auth:generate": "pnpm exec better-auth generate --config src/shared/auth/auth.server.ts --output src/shared/auth/schema.ts --yes",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/drizzle-adapter": "^1.3.8",
    "@fontsource-variable/figtree": "^5.2.10",
    "@inlang/paraglide-js": "^2.3.2",
    "@inlang/plugin-message-format": "^4.0.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@neondatabase/serverless": "^1.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/router-plugin": "^1.166.13",
    "better-auth": "^1.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "drizzle-kit": "^0.31.5",
    "web-vitals": "^5.1.0"
  }
}
